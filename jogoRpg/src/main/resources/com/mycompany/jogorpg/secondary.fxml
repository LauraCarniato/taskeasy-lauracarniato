<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>
<?import javafx.fxml.FXML?>
<?import javafx.scene.control.Alert?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.input.MouseEvent?>
<?import javafx.scene.layout.HBox?>

<VBox alignment="CENTER" style="-fx-background-color: #800000" spacing="20.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.jogorpg.SecondaryController">
    <children>

        <ListView fx:id="listaPersonagens"
          prefWidth="400"
          prefHeight="300"/>

        <HBox spacing="10" >
            
         <Button text="Entrar no jogo" onAction="#entrarNoJogo"
         style="-fx-background-color: #f0e68c"/>
        
        <Button text="Criar novo personagem" onAction="#criarPersonagem"
        style="-fx-background-color: #f0e68c"/>
        
        <Button text="Voltar" onAction="#voltar"
        style="-fx-background-color: #f0e68c"/>
        
        </HBox>

    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>
