<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>

<AnchorPane fx:id="paneJogo"
            prefWidth="800"
            prefHeight="600"
            xmlns="http://javafx.com/javafx/8.0.171"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.jogorpg.GameController"
            style="-fx-background-color: #2f4f4f;">

    <children>

        <Label text="TELA DO JOGO"
               layoutX="20"
               layoutY="20"
               style="-fx-text-fill: white; -fx-font-size: 20px;" />

        <ImageView fx:id="player"
                   fitWidth="80"
                   fitHeight="80"
                   layoutX="100"
                   layoutY="100"
                   preserveRatio="true" />

    </children>

</AnchorPane>
