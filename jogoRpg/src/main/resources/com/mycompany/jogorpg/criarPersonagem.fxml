<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="20.0"
      xmlns="http://javafx.com/javafx/8.0.171"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mycompany.jogorpg.CriarPersonagemController"
      style="-fx-background-color: #800000;">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <children>

        <Label text="Criar Personagem"
               style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: white;" />

        <TextField fx:id="campoNome"
                   promptText="Nome do personagem"
                   maxWidth="250" />

        <ChoiceBox fx:id="escolhaClasse"
                   maxWidth="250" />

        <Label text="Escolha a aparência"
               style="-fx-text-fill: white; -fx-font-size: 14px;" />

        <HBox alignment="CENTER" spacing="20">
            <children>

                <ImageView fx:id="imagemAparencia1"
                           fitWidth="100"
                           fitHeight="100"
                           preserveRatio="true"
                           onMouseClicked="#selecionarAparencia1" />

                <ImageView fx:id="imagemAparencia2"
                           fitWidth="100"
                           fitHeight="100"
                           preserveRatio="true"
                           onMouseClicked="#selecionarAparencia2" />

            </children>
        </HBox>

        <Button text="Salvar personagem"
                onAction="#salvarPersonagem"
                maxWidth="250"
                style="-fx-background-color: #f0e68c" />

        <Button text="Voltar"
                onAction="#voltar"
                maxWidth="250"
                style="-fx-background-color: #f0e68c" />

    </children>

</VBox>